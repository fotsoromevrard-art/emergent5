{
  "expo": {
    "name": "TPE Crypto",
    "slug": "tpe-crypto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tpe-crypto",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tpecrypto.app",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Cette application utilise le Bluetooth pour communiquer avec le lecteur de carte bR301-BLE",
        "NSBluetoothPeripheralUsageDescription": "Cette application utilise le Bluetooth pour communiquer avec le lecteur de carte bR301-BLE",
        "NSLocationWhenInUseUsageDescription": "La localisation est nécessaire pour le scan Bluetooth",
        "NSLocationAlwaysUsageDescription": "La localisation est nécessaire pour le scan Bluetooth"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1E3A5F"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.tpecrypto.app",
      "permissions": [
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.USB_PERMISSION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1E3A5F"
        }
      ],
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": true,
          "modes": ["peripheral", "central"],
          "bluetoothAlwaysPermission": "Cette application utilise le Bluetooth pour communiquer avec le lecteur de carte bR301-BLE"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "La localisation est nécessaire pour détecter les appareils Bluetooth à proximité."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "tpe-crypto-app"
      }
    }
  }
}
