{
  "name": "emergent5-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "build": "eas build --platform all"
  },
  "dependencies": {
    "expo": "^48.0.0",
    "expo-router": "^1.6.6",
    "expo-status-bar": "~1.4.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.71.8",
    "react-native-gesture-handler": "~2.9.0",
    "react-native-reanimated": "~3.4.0",
    "react-native-safe-area-context": "4.5.0",
    "react-native-screens": "~3.20.0",
    "react-native-usb-serialport-for-android": "^0.5.0",
    "react-native-web": "~0.18.10"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "typescript": "^5.2.0",
    "@types/react": "~18.2.7",
    "@types/react-native": "~0.71.0"
  },
  "engines": {
    "node": ">=20.19.4",
    "npm": ">=10.8.2"
  },
  "main": "index.js",
  "expo": {
    "name": "emergent5",
    "slug": "emergent5",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["ios","android","web"],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fotsoromevrard.emergent5"
    },
    "android": {
      "package": "com.fotsoromevrard.emergent5",
      "permissions": ["BLUETOOTH","BLUETOOTH_ADMIN","USB_PERMISSION"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
